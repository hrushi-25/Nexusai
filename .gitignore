# ============================================================
#  .gitignore — Files that must NEVER be pushed to GitHub
# ============================================================

# ── Secrets ──────────────────────────────────────────────────
.env
serviceAccountKey.json
*.pem
*.key

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ──────────────────────────────────────
venv/
env/
.venv/
.env/

# ── IDEs ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
