# ============================================================
#  .env  — YOUR REAL SECRETS GO HERE
#  ⚠ NEVER commit this file to GitHub
#  ⚠ This file is listed in .gitignore
# ============================================================

# Flask
FLASK_SECRET_KEY=replace-with-a-long-random-string-eg-64chars
FLASK_DEBUG=true

# OpenRouter — get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-PASTE-YOUR-KEY-HERE

# Firebase — paste the ENTIRE content of serviceAccountKey.json as one line
# (remove all newlines from the JSON before pasting)
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
